# ── Copy this to .env.prod and fill in all values before running deploy.sh ────

# ── Database ──────────────────────────────────────────────────────────────────
# Use strong random credentials — never the same as dev
POSTGRES_USER=reviewlens
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=reviewlens
DATABASE_URL=postgresql+asyncpg://reviewlens:REPLACE_WITH_STRONG_PASSWORD@db:5432/reviewlens
REDIS_URL=redis://redis:6379

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX
ADMIN_API_KEY=REPLACE_WITH_RANDOM_32_CHAR_HEX

# ── URLs (must match your actual domain) ─────────────────────────────────────
BACKEND_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Since nginx serves frontend and API on the same domain, CORS_ORIGINS can be empty.
# Only add origins if you serve from a separate domain.
CORS_ORIGINS=[]

# ── OAuth (optional) ──────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: Settings → Developer Settings → OAuth Apps
# Callback URL: https://yourdomain.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email / Password Reset ────────────────────────────────────────────────────
# Leave SMTP_HOST empty to log reset links to stdout (not recommended for production)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your@email.com
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM=noreply@yourdomain.com

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=
