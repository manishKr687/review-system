# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://reviewlens:reviewlens@db:5432/reviewlens
REDIS_URL=redis://redis:6379

# ── Secrets (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX
ADMIN_API_KEY=REPLACE_WITH_RANDOM_32_CHAR_HEX

# ── URLs (set to your real domain in production) ──────────────────────────────
BACKEND_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── CORS — list every frontend origin that should be allowed ──────────────────
# Example: CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
CORS_ORIGINS=[]

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to enforce secure secrets and disable localhost CORS
ENVIRONMENT=production

# ── OAuth (optional) ──────────────────────────────────────────────────────────
# Google → https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: https://api.yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub → Settings → Developer Settings → OAuth Apps
# Authorization callback URL: https://api.yourdomain.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email / Password Reset ────────────────────────────────────────────────────
# Leave SMTP_HOST empty to log reset links to stdout instead of sending email
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────────────
SENTRY_DSN=
